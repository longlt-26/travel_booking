# =========================
# Database
# =========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=travel_booking
DB_USERNAME=root
DB_PASSWORD=

# =========================
# VNPAY (VNPay) - để thanh toán thật
# =========================
# Tham khảo cấu hình VNPay từ phía cổng thanh toán.
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET

# Tùy chọn (khuyến nghị)
# VNPAY_RETURN_URL=http://127.0.0.1:8000/payment/vnpay/return
# VNPAY_NOTIFY_URL=http://127.0.0.1:8000/payment/vnpay/callback

# =========================
# Momo (MoMo) - để thanh toán thật
# =========================
# Cần set đầy đủ theo merchant
# MOMO_PARTNER_CODE=YOUR_PARTNER_CODE
# MOMO_ACCESS_KEY=YOUR_ACCESS_KEY
# MOMO_SECRET_KEY=YOUR_SECRET_KEY

